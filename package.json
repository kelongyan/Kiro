{
  "name": "kiro-account-manager",
  "version": "1.7.0",
  "description": "Kiro Account Manager - Manage your Kiro accounts, usage and subscriptions",
  "main": "./out/server/standalone.mjs",
  "author": "Kiro",
  "license": "AGPL-3.0",
  "homepage": "https://kiro.dev",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "npm run serve",
    "dev": "npm run dev:web",
    "build": "npm run typecheck && npm run serve:build && npm run build:web",
    "serve:build": "vite build --config vite.server.config.ts",
    "serve:smoke": "npm run serve:build && node out/server/standalone.mjs --smoke",
    "serve": "npm run serve:build && node out/server/standalone.mjs",
    "dev:web": "vite --config vite.config.ts --host 127.0.0.1",
    "build:web": "vite build --config vite.config.ts",
    "preview:web": "vite preview --config vite.config.ts --host 127.0.0.1",
    "test:e2e": "node test/e2e-fullsuite/run.mjs",
    "test:e2e:only": "node test/e2e-fullsuite/run.mjs --only"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-virtual": "^3.13.12",
    "cbor-x": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^0.555.0",
    "node-forge": "^1.3.3",
    "socks": "^2.8.9",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "tlsclientwrapper": "^4.2.0",
    "undici": "^7.19.2",
    "uuid": "^13.0.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/node": "^22.18.6",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.3",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.1.6"
  }
}
